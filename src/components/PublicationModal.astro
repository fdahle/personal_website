---
import { SITE_TITLE } from '../consts';
---

<!-- BibTeX cite modal -->
<div
  id="pub-cite-modal"
  class="fixed inset-0 z-[60] flex items-center justify-center bg-black/60 backdrop-blur-sm hidden py-8 px-4"
  role="dialog"
  aria-modal="true"
  aria-label="BibTeX citation"
>
  <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl max-w-xl w-full relative">
    <button
      id="pub-cite-close"
      class="absolute top-3 right-3 z-10 p-1.5 text-slate-400 dark:text-slate-500 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
      aria-label="Close"
    >
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <div class="p-6">
      <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-3">BibTeX</h3>
      <pre id="pub-cite-content" class="text-xs font-mono bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl p-4 whitespace-pre overflow-x-auto text-slate-700 dark:text-slate-300 leading-relaxed mb-4"></pre>
      <div class="flex gap-2 justify-end text-xs">
        <button
          id="pub-cite-copy"
          class="px-4 py-1.5 rounded-full bg-teal-700 hover:bg-teal-600 text-white font-medium transition-colors cursor-pointer flex items-center gap-1.5"
        >
          <i class="fa-regular fa-copy"></i> Copy
        </button>
        <button
          id="pub-cite-close-btn"
          class="px-4 py-1.5 rounded-full bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 font-medium transition-colors cursor-pointer"
        >
          Close
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Publication detail modal — include once per page that uses PublicationCard -->
<div
  id="pub-detail-modal"
  data-author-name={SITE_TITLE}
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm hidden overflow-y-auto py-8 px-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="pub-detail-title"
>
  <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl max-w-2xl w-full relative my-auto">
    <!-- Close button -->
    <button
      id="pub-detail-close"
      class="absolute top-3 right-3 z-10 p-1.5 text-slate-400 dark:text-slate-500 hover:text-slate-700 dark:hover:text-slate-200 transition-colors"
      aria-label="Close"
    >
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>

    <!-- Image (hidden when not available) -->
    <div id="pub-detail-img-wrap">
      <img
        id="pub-detail-img"
        src=""
        alt=""
        class="w-full aspect-video object-cover rounded-t-2xl"
      />
    </div>

    <!-- Content -->
    <div class="p-6 pt-5">
      <!-- Venue + year + open-access badge -->
      <p id="pub-detail-meta" class="text-xs font-semibold uppercase tracking-wider mb-2 flex items-center gap-1.5 text-teal-700 dark:text-teal-400"></p>

      <h2 id="pub-detail-title" class="text-xl font-bold text-slate-900 dark:text-white mb-1 leading-snug pr-8"></h2>
      <p id="pub-detail-authors" class="text-sm text-slate-500 dark:text-slate-400 mb-5"></p>

      <!-- Abstract section (hidden when no text available) -->
      <div id="pub-detail-tags" class="flex flex-wrap gap-1.5 mb-4"></div>

      <div id="pub-detail-abstract-section">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-2">Abstract</h3>
        <div id="pub-detail-abstract" class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed mb-5"></div>
      </div>

      <!-- Action links / buttons -->
      <div id="pub-detail-links" class="flex flex-wrap gap-2 text-xs"></div>
    </div>
  </div>
</div>

<script>
  interface PubData {
    title?: string;
    authors?: string;
    venue?: string;
    year?: number;
    abstract?: string;
    description?: string;
    img?: string;
    doi?: string;
    pdf?: string;
    code?: string;
    openAccess?: boolean;
    bibtex?: string;
    tags?: string[];
  }

  const SHARE_ICON = '<i class="fa-solid fa-share-nodes"></i> Share';

  // ── Cite modal ──────────────────────────────────────────────────────────────
  const citeModal    = document.getElementById('pub-cite-modal')    as HTMLElement;
  const citeContent  = document.getElementById('pub-cite-content')  as HTMLElement;
  const citeCopyBtn  = document.getElementById('pub-cite-copy')     as HTMLButtonElement;
  const citeCloseBtn = document.getElementById('pub-cite-close')    as HTMLButtonElement;
  const citeCloseBtnAlt = document.getElementById('pub-cite-close-btn') as HTMLButtonElement;

  function openCiteModal(bibtex: string) {
    citeContent.textContent = bibtex;
    citeModal.classList.remove('hidden');
  }

  function closeCiteModal() {
    citeModal.classList.add('hidden');
  }

  citeCopyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(citeContent.textContent ?? '').then(() => {
      const orig = citeCopyBtn.innerHTML;
      citeCopyBtn.innerHTML = 'Copied!';
      setTimeout(() => { citeCopyBtn.innerHTML = orig; }, 2000);
    });
  });
  citeCloseBtn?.addEventListener('click', closeCiteModal);
  citeCloseBtnAlt?.addEventListener('click', closeCiteModal);
  citeModal?.addEventListener('click', (e) => { if (e.target === citeModal) closeCiteModal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && citeModal && !citeModal.classList.contains('hidden')) closeCiteModal();
  });
  // ────────────────────────────────────────────────────────────────────────────

  // Card-level cite buttons dispatch this event (PublicationCard.astro)
  document.addEventListener('open-cite-modal', (e) => {
    openCiteModal((e as CustomEvent<string>).detail);
  });

  async function sharePub(url: string, title: string, btn: HTMLElement) {
    if (navigator.share) {
      try {
        await navigator.share({ title, url });
      } catch (err) {
        // User cancelled or share failed — silently ignore
        if ((err as DOMException).name !== 'AbortError') console.warn(err);
      }
    } else {
      // Fallback: copy to clipboard
      await navigator.clipboard.writeText(url);
      const original = btn.innerHTML;
      btn.innerHTML = 'Copied!';
      setTimeout(() => { btn.innerHTML = original; }, 2000);
    }
  }

  const modal          = document.getElementById('pub-detail-modal')          as HTMLElement;
  const closeBtn       = document.getElementById('pub-detail-close')          as HTMLButtonElement;
  const imgWrap        = document.getElementById('pub-detail-img-wrap')       as HTMLElement;
  const imgEl          = document.getElementById('pub-detail-img')            as HTMLImageElement;
  const metaEl         = document.getElementById('pub-detail-meta')           as HTMLElement;
  const titleEl        = document.getElementById('pub-detail-title')          as HTMLElement;
  const authorsEl      = document.getElementById('pub-detail-authors')        as HTMLElement;
  const tagsEl         = document.getElementById('pub-detail-tags')           as HTMLElement;
  const abstractSec    = document.getElementById('pub-detail-abstract-section') as HTMLElement;
  const abstractEl     = document.getElementById('pub-detail-abstract')       as HTMLElement;
  const linksEl        = document.getElementById('pub-detail-links')          as HTMLElement;
  function renderAbstract(text: string) {
    if (!text) return '';

    // 1) Convert Markdown links [text](url) -> <a>
    let processed = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

    // 2) Protect existing anchor tags produced above so we don't double-linkify them
    const anchors: string[] = [];
    processed = processed.replace(/<a\b[^>]*>[\s\S]*?<\/a>/gi, (m) => {
      anchors.push(m);
      return `__ANCHOR_PLACEHOLDER_${anchors.length - 1}__`;
    });

    // 3) Auto-link plain URLs (http(s):// or www.)
    processed = processed.replace(/(?:https?:\/\/|www\.)[^\s<]+/gi, (url) => {
      const href = url.match(/^https?:\/\//i) ? url : `https://${url}`;
      return `<a href="${href}" target="_blank" rel="noopener noreferrer">${url}</a>`;
    });

    // 4) Restore protected anchors
    processed = processed.replace(/__ANCHOR_PLACEHOLDER_(\d+)__/g, (_, idx) => anchors[Number(idx)] ?? '');

    // 4b) Ensure links in the modal use the site link color/styling (add classes when missing)
    processed = processed.replace(/<a\b([^>]*)>/gi, (m) => {
      if (/\bclass\s*=/.test(m)) {
        // Append our classes to existing class attribute
        return m.replace(/class\s*=\s*"([^"]*)"/i, (all, cls) => {
          if (cls.includes('text-teal-700') || cls.includes('dark:text-teal-400')) return all;
          return `class="${cls} text-teal-700 dark:text-teal-400 hover:underline"`;
        });
      }
      // No class attribute — add one
      return m.replace('<a', '<a class="text-teal-700 dark:text-teal-400 hover:underline"');
    });

    // 5) Split into paragraphs (two or more newlines) and collapse single newlines to spaces
    const paragraphs = processed
      .split(/\n{2,}/)
      .map(p => p.replace(/\n+/g, ' ').trim())
      .filter(Boolean)
      .map(p => `<p class="mb-3">${p}</p>`)
      .join('');

    return paragraphs;
  }

  function openPubModal(data: PubData) {
    // Image
    if (data.img) {
      imgEl.src = data.img;
      imgEl.alt = data.title ?? '';
      imgWrap.style.display = '';
    } else {
      imgWrap.style.display = 'none';
    }

    // Meta line: open-access icon · venue · year
    const oaIcon = data.openAccess
      ? '<span class="text-amber-500" title="Open Access"><i class="ai ai-open-access"></i></span>'
      : '<span class="text-slate-400" title="Closed Access"><i class="ai ai-closed-access"></i></span>';
    const venueYear = [data.venue, data.year ? String(data.year) : ''].filter(Boolean).join(' · ');
    metaEl.innerHTML = `${oaIcon} <span>${venueYear}</span>`;

    titleEl.textContent   = data.title   ?? '';
    // Bold the site author's name in the authors list (client-side)
    const authorName = modal?.dataset.authorName ?? 'Felix Dahle';
    function escapeRegExp(s){ return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
    const re = new RegExp(escapeRegExp(authorName), 'g');
    const authorsHtml = (data.authors ?? '').replace(re, `<strong class="font-semibold text-slate-900 dark:text-white">${authorName}</strong>`);
    authorsEl.innerHTML = authorsHtml;

    // Tags
    tagsEl.innerHTML = '';
    if (data.tags && data.tags.length > 0) {
      data.tags.forEach(tag => {
        const slug = tag.toLowerCase().replace(/\s+/g, '-');
        const a = document.createElement('a');
        a.href = `/tags/${slug}`;
        a.textContent = tag;
        a.className = 'text-xs px-2 py-0.5 rounded-full bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400 border border-teal-200 dark:border-teal-800 hover:bg-teal-100 dark:hover:bg-teal-900/60 transition-colors no-underline';
        tagsEl.appendChild(a);
      });
      tagsEl.style.display = '';
    } else {
      tagsEl.style.display = 'none';
    }

    // Abstract — prefer explicit abstract field, fall back to description
    const text = data.abstract || data.description || '';
    if (text) {
      abstractEl.innerHTML  = renderAbstract(text);
      abstractSec.style.display = '';
    } else {
      abstractSec.style.display = 'none';
    }

    // Action buttons / links
    linksEl.innerHTML = '';
    const btnBase = 'px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 hover:bg-slate-200 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-300 font-medium transition-colors no-underline';

    function addLink(href: string, label: string) {
      const a = document.createElement('a');
      a.href = href; a.target = '_blank'; a.rel = 'noopener noreferrer';
      a.className = btnBase; a.textContent = label;
      linksEl.appendChild(a);
    }

    // Share button (leftmost)
    if (data.slug) {
      const shareBtn = document.createElement('button');
      shareBtn.className = btnBase + ' cursor-pointer inline-flex items-center gap-1.5';
      shareBtn.innerHTML = '<i class="fa-solid fa-share-nodes"></i> Share';
      shareBtn.title = 'Share';
      shareBtn.addEventListener('click', () => {
        const url = window.location.origin + '/publications#' + data.slug;
        sharePub(url, data.title ?? '', shareBtn);
      });
      linksEl.appendChild(shareBtn);
      const sep = document.createElement('span');
      sep.className = 'w-px h-5 bg-slate-200 dark:bg-slate-700';
      sep.setAttribute('aria-hidden', 'true');
      linksEl.appendChild(sep);
    }

    if (data.doi)  addLink(data.doi,  'DOI');
    if (data.pdf)  addLink(data.pdf,  'PDF');
    if (data.code) addLink(data.code, 'Code');

    if (data.bibtex) {
      const btn = document.createElement('button');
      btn.className = btnBase + ' cursor-pointer';
      btn.textContent = 'Cite';
      btn.addEventListener('click', () => openCiteModal(data.bibtex!));
      linksEl.appendChild(btn);
    }

    // Update URL hash
    if (data.slug) {
      history.replaceState(null, '', '#' + data.slug);
    }

    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closePubModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    history.replaceState(null, '', window.location.pathname + window.location.search);
  }

  closeBtn?.addEventListener('click', closePubModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closePubModal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closePubModal();
  });

  // Event delegation: click on any [data-pub] element (not on a nested link/button) opens the modal
  document.addEventListener('click', (e) => {
    const card = (e.target as Element).closest('[data-pub]');
    if (!card) return;
    if ((e.target as Element).closest('a, button')) return;
    try {
      const data: PubData = JSON.parse((card as HTMLElement).dataset.pub ?? '{}');
      openPubModal(data);
    } catch { /* malformed JSON */ }
  });

  // Share-button clicks on cards
  document.addEventListener('click', (e) => {
    const shareBtn = (e.target as Element).closest('.share-btn') as HTMLElement | null;
    if (!shareBtn) return;
    const slug = shareBtn.dataset.shareSlug;
    if (!slug) return;
    const url = window.location.origin + '/publications#' + slug;
    // Try to get the publication title from the card's data-pub
    let title = '';
    try {
      const wrapper = shareBtn.closest('[data-pub]') as HTMLElement | null;
      if (wrapper?.dataset.pub) title = JSON.parse(wrapper.dataset.pub).title ?? '';
    } catch { /* ignore */ }
    sharePub(url, title, shareBtn);
  });

  // Auto-open modal when page loads with a hash that matches a publication slug
  const initialHash = window.location.hash.slice(1);
  if (initialHash) {
    const wrapper = document.getElementById(initialHash);
    const card = wrapper?.querySelector('[data-pub]') as HTMLElement | null;
    if (card?.dataset.pub) {
      try {
        const data: PubData = JSON.parse(card.dataset.pub);
        openPubModal(data);
      } catch { /* malformed JSON */ }
    }
  }
</script>
