---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import '../styles/blog.css';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

// ── Citation ───────────────────────────────────────────────────────────────
const year  = pubDate.getFullYear();
const months = ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
const month = months[pubDate.getMonth()];
const keyWord = title.split(/\W+/).find((w: string) => w.length > 3)?.toLowerCase() ?? 'post';
const citeKey = `dahle${year}${keyWord}`;
const postUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const bibtex = `@misc{${citeKey},
  author = {Dahle, Felix},
  title  = {{${title}}},
  year   = {${year}},
  month  = ${month},
  url    = {${postUrl}},
  note   = {Blog post}
}`;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 antialiased">
    <Header />
    <main class="max-w-3xl mx-auto px-6 py-12">
      <article>
        {heroImage && (
          <div class="mb-8">
            <Image width={1020} height={510} src={heroImage} alt=""
              class="w-full rounded-xl shadow-md object-cover" />
          </div>
        )}
        <header class="mb-8 pb-8 border-b border-slate-200 dark:border-slate-700 text-center">
          <p class="text-sm text-slate-400 dark:text-slate-500 mb-2">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="italic"> &middot; Updated <FormattedDate date={updatedDate} /></span>
            )}
          </p>
          <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white leading-tight">{title}</h1>
          {tags && tags.length > 0 && (
            <div class="flex flex-wrap justify-center gap-1.5 mt-4">
              {tags.map(tag => (
                <a
                  href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                  class="text-xs px-2.5 py-0.5 rounded-full bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400 border border-teal-200 dark:border-teal-800 hover:bg-teal-100 dark:hover:bg-teal-900/60 transition-colors no-underline"
                >{tag}</a>
              ))}
            </div>
          )}
          <div class="flex justify-center mt-4">
            <button
              id="blog-share-btn"
              data-title={title}
              data-url={postUrl}
              class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 transition-colors cursor-pointer"
            >
              <i class="fa-solid fa-share-nodes"></i> Share
            </button>
          </div>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>

      <!-- ── Cite this post ──────────────────────────────────────────────── -->
      <section class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
        <h2 class="text-base font-bold text-slate-900 dark:text-white mb-3">Cite</h2>
        <div class="relative">
          <pre id="bibtex-block" class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg p-4 overflow-x-auto leading-relaxed font-mono border border-slate-200 dark:border-slate-700 whitespace-pre"><code>{bibtex}</code></pre>
          <button
            id="copy-bibtex"
            class="absolute top-2 right-2 p-1.5 rounded text-slate-400 hover:text-teal-700 dark:hover:text-teal-400 transition-colors"
            aria-label="Copy BibTeX"
            title="Copy BibTeX to clipboard"
          >
            <i class="fa-regular fa-copy text-sm"></i>
          </button>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script>
  const btn = document.getElementById('copy-bibtex') as HTMLButtonElement | null;
  const pre = document.getElementById('bibtex-block') as HTMLPreElement | null;
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText(pre?.innerText ?? '');
    btn.innerHTML = '<i class="fa-solid fa-check text-sm text-teal-600 dark:text-teal-400"></i>';
    setTimeout(() => {
      btn.innerHTML = '<i class="fa-regular fa-copy text-sm"></i>';
    }, 1500);
  });

  const shareBtn = document.getElementById('blog-share-btn') as HTMLButtonElement | null;
  shareBtn?.addEventListener('click', async () => {
    const title = shareBtn.dataset.title ?? '';
    const url   = shareBtn.dataset.url   ?? window.location.href;
    if (navigator.share) {
      try {
        await navigator.share({ title, url });
      } catch (err) {
        if ((err as DOMException).name !== 'AbortError') console.warn(err);
      }
    } else {
      await navigator.clipboard.writeText(url);
      const orig = shareBtn.innerHTML;
      shareBtn.innerHTML = 'Copied!';
      setTimeout(() => { shareBtn.innerHTML = orig; }, 2000);
    }
  });
</script>
