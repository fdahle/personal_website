---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import '../../styles/blog.css';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
  .filter(post => import.meta.env.DEV || post.data.published !== false)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 antialiased">
    <Header />
    <main class="max-w-4xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-8">Blog</h1>
      {posts.length === 0 ? (
        <p class="text-slate-400 dark:text-slate-500">No posts yet — check back soon.</p>
      ) : (
        <ul class="space-y-5 list-none p-0 m-0">
          {posts.map(post => (
            <li>
              <a href={`/blog/${post.id}/`}
                class="group flex flex-col sm:flex-row gap-5 p-5 bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-shadow no-underline text-inherit">
                {post.data.heroImage && (
                  <div class="w-full sm:w-44 flex-shrink-0 overflow-hidden rounded-lg">
                    <Image
                      src={post.data.heroImage}
                      width={300} height={180}
                      alt=""
                      class="w-full h-32 sm:h-full object-cover rounded-lg"
                    />
                  </div>
                )}
                <div class="flex flex-col justify-center">
                  <p class="text-xs text-slate-400 dark:text-slate-500 mb-1.5">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  <h2 class="text-base font-bold text-slate-900 dark:text-white mb-1 group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
    <Footer />
  </body>
</html>
