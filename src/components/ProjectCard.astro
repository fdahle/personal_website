---
import fs from 'fs';
import path from 'path';

interface Props {
  title: string;
  description?: string;
  link?: string;
  repo?: string;
  img?: string;
  tags?: string[];
  slug?: string;
  wip?: boolean;
}

const { title, description, link, repo, img, tags = [], slug, wip } = Astro.props;

const exts = ['webp', 'png', 'jpg', 'jpeg', 'svg'];

function publicExists(rel: string) {
  return fs.existsSync(path.join(process.cwd(), 'public', rel));
}

let finalImg: string | undefined;

if (img) {
  const s = String(img).trim();
  if (/^https?:\/\//i.test(s)) {
    finalImg = s;
  } else if (s.startsWith('/')) {
    const trimmed = s.replace(/^\//, '');
    if (publicExists(trimmed)) finalImg = `/${trimmed}`;
    else finalImg = s;
  } else {
    // Try as path under public
    if (publicExists(s)) {
      finalImg = `/${s.replace(/\\\\/g, '/')}`;
    } else if (publicExists(path.join('img', 'projects', s))) {
      finalImg = `/img/projects/${s}`;
    } else {
      const hasExt = /\.[a-zA-Z0-9]+$/.test(s);
      if (!hasExt) {
        for (const ext of exts) {
          if (publicExists(path.join('img', 'projects', `${s}.${ext}`))) {
            finalImg = `/img/projects/${s}.${ext}`;
            break;
          }
        }
      } else {
        // last attempt: try under img/projects using basename
        const basename = path.basename(s);
        if (publicExists(path.join('img', 'projects', basename))) finalImg = `/img/projects/${basename}`;
        else finalImg = `/${s.replace(/\\\\/g, '/')}`;
      }
    }
  }
}

// fallback by slug
if (!finalImg && slug) {
  for (const ext of exts) {
    if (publicExists(path.join('img', 'projects', `${slug}.${ext}`))) {
      finalImg = `/img/projects/${slug}.${ext}`;
      break;
    }
  }
}

---

<article class="p-4 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-sm hover:shadow-md transition-shadow">
  <div class="flex items-start gap-4">
    {finalImg ? (
      <img src={finalImg} alt={`Screenshot of ${title}`} width="80" height="80" loading="lazy" decoding="async" class="w-20 h-20 object-cover rounded-md" />
    ) : (
      <div class="w-20 h-20 rounded-md bg-gradient-to-br from-teal-100 to-cyan-200 flex items-center justify-center">
        <i class="fa-regular fa-folder-open text-2xl text-white/70"></i>
      </div>
    )}

    <div class="flex-1 flex flex-col justify-between">
      <div class="flex items-start justify-between gap-2 mb-1">
        <h3 class="text-sm font-bold text-slate-900 dark:text-white">{title}</h3>
        {wip && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 border border-amber-300 dark:border-amber-700 text-xs font-medium whitespace-nowrap flex-shrink-0">
            <i class="fa-solid fa-triangle-exclamation"></i> In Development
          </span>
        )}
      </div>
      {description && <p class="text-xs text-slate-600 dark:text-slate-400 mb-3 leading-relaxed">{description}</p>}

      <div class="flex items-center gap-2">
        {link && (
          <a href={link} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300 text-xs font-medium hover:bg-slate-200 dark:hover:bg-slate-600 no-underline">
            <i class="fa-solid fa-globe"></i> Live
          </a>
        )}
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-50 dark:bg-slate-700/40 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 text-xs font-medium hover:bg-slate-100 dark:hover:bg-slate-700 no-underline">
            <i class="fa-brands fa-github"></i> Repo
          </a>
        )}

        {tags.length > 0 && (
          <div class="ml-auto flex flex-wrap gap-1">
            {tags.map(t => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-teal-50 dark:bg-teal-900/30 text-teal-700 dark:text-teal-400 border border-teal-200 dark:border-teal-800">{t}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</article>
