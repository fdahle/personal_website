---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Privacy Policy — ${SITE_TITLE}`} description="Privacy policy for Felix Dahle's personal research website." />
  </head>
  <body class="bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-200 antialiased">
    <Header />

    <main class="max-w-2xl mx-auto px-6 py-14">
      <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-2">Privacy Policy</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-10">Last updated: April 2026</p>

      <div class="space-y-8 text-sm text-slate-700 dark:text-slate-300 leading-relaxed">

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Who I am</h2>
          <p>
            This is the personal research website of Felix Dahle. You can reach me via the
            <a href="/contact" class="text-teal-700 dark:text-teal-400 hover:underline">contact form</a>
            on this site.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Data I collect</h2>
          <p>
            This website does not use analytics, tracking scripts, or advertising. I do not collect,
            store, or process any personal data directly — with one exception: the contact form.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Contact form (Formspree)</h2>
          <p>
            The contact form on this site is powered by{' '}
            <a href="https://formspree.io" target="_blank" rel="noopener noreferrer"
              class="text-teal-700 dark:text-teal-400 hover:underline">Formspree</a>.
            When you submit the form, your name, email address, and message are sent to and processed
            by Formspree on my behalf. I use this information solely to respond to your message.
            Please refer to{' '}
            <a href="https://formspree.io/legal/privacy-policy/" target="_blank" rel="noopener noreferrer"
              class="text-teal-700 dark:text-teal-400 hover:underline">Formspree's Privacy Policy</a>
            {' '}for details on how they handle your data.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Third-party services &amp; CDNs</h2>
          <p>
            This site loads certain resources from third-party content delivery networks:
            jsDelivr (<code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 py-0.5 rounded">cdn.jsdelivr.net</code>)
            and Cloudflare CDNJS (<code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 py-0.5 rounded">cdnjs.cloudflare.com</code>).
            These services may log standard request metadata such as your IP address and browser type
            as part of normal CDN operation. No personal data is passed to them from this site.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Server logs</h2>
          <p>
            Like any website, my hosting provider may automatically log basic technical information
            (IP address, browser, pages visited) for security and operational purposes. These logs
            are not used for profiling or marketing.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Cookies</h2>
          <p>
            This site does not use cookies for analytics or tracking. CDNs may set short-lived
            technical cookies; these are not used to identify you.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Your rights (GDPR)</h2>
          <p>
            If you are located in the EU/EEA, you have the right to access, correct, or request
            deletion of any personal data you have submitted (e.g. via the contact form). To
            exercise these rights, please contact me directly or reach out to Formspree if the
            request concerns data they hold. You also have the right to lodge a complaint with the
            Dutch data protection authority:{' '}
            <a href="https://www.autoriteitpersoonsgegevens.nl" target="_blank" rel="noopener noreferrer"
              class="text-teal-700 dark:text-teal-400 hover:underline">Autoriteit Persoonsgegevens</a>.
          </p>
        </section>

        <section>
          <h2 class="text-base font-bold text-slate-900 dark:text-white mb-2">Changes to this policy</h2>
          <p>
            If anything significant changes (e.g. I add analytics), I will update this page and
            the date above.
          </p>
        </section>

      </div>
    </main>

    <Footer />
  </body>
</html>
